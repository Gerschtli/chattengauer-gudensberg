{
	"name": "chattengauer-gudensberg",
	"version": "0.0.1",
	"private": true,
	"engines": {
		"node": "24.x"
	},
	"packageManager": "pnpm@11.1.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"test": "pnpm run test:unit run",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint --max-warnings=0 .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"storyblok:pull-components": "storyblok components pull && storyblok types generate --strict",
		"storyblok:push-components": "storyblok components push"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.0",
		"@eslint/js": "^9.25.1",
		"@storyblok/richtext": "^3.2.0",
		"@storyblok/svelte": "^6.1.7",
		"@sveltejs/adapter-vercel": "^6.0.0",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.1.4",
		"@trivago/prettier-plugin-sort-imports": "^6.0.0",
		"@types/eslint": "^9.6.1",
		"@types/node": "^24.12.4",
		"@types/nodemailer": "^8.0.0",
		"@typescript-eslint/eslint-plugin": "^8.31.0",
		"@typescript-eslint/parser": "^8.31.0",
		"@vitejs/plugin-basic-ssl": "^2.0.0",
		"dedent": "^1.5.3",
		"eslint": "^9.25.1",
		"eslint-config-prettier": "^10.1.2",
		"eslint-plugin-svelte": "^3.5.1",
		"formsnap": "^2.0.1",
		"globals": "^17.0.0",
		"ical.js": "^2.1.0",
		"lucide-svelte": "^1.0.0",
		"nodemailer": "^8.0.0",
		"prettier": "^3.5.3",
		"prettier-plugin-css-order": "^2.1.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"storyblok": "^4.17.7",
		"svelte": "^5.55.9",
		"svelte-check": "^4.1.6",
		"sveltekit-superforms": "^2.24.1",
		"tailwindcss": "^4.1.4",
		"tslib": "^2.8.1",
		"typescript": "^6.0.0",
		"typescript-eslint": "^8.31.0",
		"vite": "^8.0.0",
		"vitest": "^4.0.0",
		"zod": "^4.1.12"
	},
	"type": "module"
}
